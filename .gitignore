# Uploads and outputs from this app (if stored locally and not versioned)
# Adjust if your app stores files elsewhere that shouldn't be versioned.
backend/TEMP_DIR/ 
# If TEMP_DIR is outside backend, adjust path e.g. /TEMP_DIR/ if it's at root
# The current code uses tempfile.mkdtemp which might be system-wide /tmp
# If so, this rule might not be strictly necessary as /tmp is usually not in a repo.
# However, if TEMP_DIR were configured to be within the project, this would be important.
# For now, let's assume it could be created inside `backend` if not system default.

# Specific to this project:
backend/.env 
frontend/.env # If frontend ever uses one

